{
  "name": "pingpilot-proximity-api",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant proximity engagement and loyalty API gateway.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker:whatsapp": "node src/workers/whatsappWorker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "check": "node --check src/server.js && node --check src/services/proximityService.js && node --check src/workers/whatsappWorker.js"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.2.0",
    "@prisma/client": "^6.1.0",
    "axios": "^1.7.9",
    "bullmq": "^5.34.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.2",
    "prisma": "^6.1.0"
  }
}
